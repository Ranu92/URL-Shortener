# Postgres connection. For Supabase use the connection string from
# Project Settings -> Database. Percent-encode any special chars in the
# password (e.g. "@" -> "%40"). Append ?sslmode=require for cloud Postgres.
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require

# Salt used to hash visitor IPs before storage (set to a long random string)
IP_HASH_SALT=change-me-to-a-long-random-string

# Rate limiting for link creation
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Base URL used to build returned short URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
